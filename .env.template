# ==============================================================================
# 애드픽 & GitHub Pages 블로그 자동화 환경변수 템플릿
# 복사하여 .env 파일을 만들고 실제 키 값들을 채워넣으세요.
# ==============================================================================

# 애드픽 회원 고유 ID (예: 06f76e)
ADPICK_AFFID=your_adpick_affid_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (선택 사항, Gemini 실패 시 Fallback으로 활용)
OPENAI_API_KEY=your_openai_api_key_here

# 텔레그램 발행 완료 알림용 토큰 및 챗 ID (선택 사항)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
